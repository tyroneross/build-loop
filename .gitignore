# OS
.DS_Store
Thumbs.db

# Runtime data (created in consumer projects)
.build-loop/
.claude/
.codex/
.agent-rally-point/

# Runtime memory/state. Durable memory belongs in the private
# build-loop-memory repo, never in this public plugin repo.
.episodic/
.semantic/
.procedural/

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# Node (if scripts added later)
node_modules/

# Plan artifacts (local only)
docs/superpowers/

# Python cache
__pycache__/
*.pyc

# Python build/venv artifacts
.venv/
*.egg-info/
.pytest_cache/

# Consumer-project artifacts (generated by build-loop runs)
.localsmartz/

# >>> NavGator safety guard (auto-managed)
# These files are regenerated from .env on every NavGator scan and contain
# parsed hostnames/endpoints from your live environment. Credentials are
# stripped by NavGator, but hostnames/project refs still leak infra identity.
# Safe to delete this block if you want the files tracked — NavGator will
# not re-add it while the markers below are missing.
.navgator/architecture/components/COMP_config_*.json
.navgator/architecture/NAVSUMMARY.md
.navgator/architecture/NAVSUMMARY_FULL.md
.navgator/architecture/SUMMARY.md
.navgator/architecture/SUMMARY_FULL.md
# <<< NavGator safety guard

# Build-loop runtime artifacts
.in_use/

# Bookmark snapshot data
.bookmark/

# Private-slug guard runtime config (real slugs — never tracked).
# See .private-slugs.example for the format.
.private-slugs

# Rally coordination: keep the canonical ledger, ignore derived/runtime cache.
.rally/facts.db
.rally/facts.db-shm
.rally/facts.db-wal
.rally/room.db
.rally/cursors.json
.rally/*.tmp-*

# Tool-data directories — never tracked (CLAUDE.md: tool data under .<toolname>/).
# Broadens the NavGator safety guard above to the whole dir — components.full.jsonl
# carries env-parsed hostnames (infra identity). Nothing here is currently tracked.
.navgator/
.ibr/
.claude-code-debugger/
