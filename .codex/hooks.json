{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "NPX=\"$(command -v npx 2>/dev/null || true)\"; [ -n \"$NPX\" ] && \"$NPX\" @tyroneross/bookmark precompact 2>/dev/null || printf '{}'",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "NPX=\"$(command -v npx 2>/dev/null || true)\"; [ -n \"$NPX\" ] && \"$NPX\" @tyroneross/bookmark restore 2>/dev/null || printf '{}'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"; bash \"$root/hooks/closeout.sh\" session-start </dev/null 2>/dev/null || printf '{}'",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"; pkg=\"$root/scripts/rally_point\"; host_parent=\"${PPID:-0}\"; [ -f \"$pkg/session_probe.py\" ] && WORKDIR=\"$root\" python3 \"$pkg/session_probe.py\" --workdir \"$root\" --tool codex --mode hook --start-watch --watch-parent-pid \"$host_parent\" >/dev/null 2>&1 || printf '{}'",
            "timeout": 4000
          },
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"; bash \"$root/hooks/session-start-git-hooks.sh\" </dev/null >/dev/null 2>&1; printf '{}'",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NPX=\"$(command -v npx 2>/dev/null || true)\"; [ -n \"$NPX\" ] && \"$NPX\" @tyroneross/bookmark stop 2>/dev/null || printf '{\"decision\": \"approve\"}'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"; bash \"$root/hooks/closeout.sh\" stop 2>/dev/null || printf '{}'",
            "timeout": 6000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "NPX=\"$(command -v npx 2>/dev/null || true)\"; [ -n \"$NPX\" ] && \"$NPX\" @tyroneross/claude-code-debugger mine --days 1 --store 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v rally >/dev/null 2>&1 && rally stop codex --json >/dev/null 2>&1 || true",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
