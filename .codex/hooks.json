{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx @tyroneross/bookmark precompact 2>/dev/null || echo '{}'",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx @tyroneross/bookmark restore 2>/dev/null || echo '{}'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"; bash \"$root/hooks/closeout.sh\" session-start </dev/null 2>/dev/null || printf '{}'",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"; pkg=\"$root/scripts/rally_point\"; [ -f \"$pkg/session_probe.py\" ] && WORKDIR=\"$root\" python3 \"$pkg/session_probe.py\" --workdir \"$root\" --tool codex --mode hook >/dev/null 2>&1 || printf '{}'",
            "timeout": 4000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx @tyroneross/bookmark stop 2>/dev/null || echo '{\"decision\": \"approve\"}'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"; bash \"$root/hooks/closeout.sh\" stop 2>/dev/null || printf '{}'",
            "timeout": 6000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx @tyroneross/claude-code-debugger mine --days 1 --store 2>/dev/null || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v rally >/dev/null 2>&1 && rally stop codex --json >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
